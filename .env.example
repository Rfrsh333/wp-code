# =============================================================================
# TopTalent Jobs - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git!
# =============================================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Authentication ---
JWT_SECRET=                          # Generate with: openssl rand -hex 32
ADMIN_EMAILS=                        # Comma-separated admin emails
ADMIN_ROLE_MAP=                      # JSON: {"email":"role"}

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=               # From Resend dashboard → Webhooks

# --- Redis (Upstash) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Telegram Alerts ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Cron Jobs ---
CRON_SECRET=                         # Generate with: openssl rand -hex 32

# --- Kandidaat Onboarding ---
KANDIDAAT_TOKEN_SECRET=              # Generate with: openssl rand -hex 32

# --- reCAPTCHA ---
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# --- Site URL ---
NEXT_PUBLIC_SITE_URL=https://www.toptalentjobs.nl
NEXT_PUBLIC_BASE_URL=https://www.toptalentjobs.nl

# --- Contact ---
CONTACT_PHONE_NUMBER=+31 6 17 17 79 39

# --- OpenAI (AI features: lead research, content generation, email drafting) ---
OPENAI_API_KEY=
OPENAI_CONTENT_MODEL=gpt-4o          # Model for content generation
OPENAI_IMAGE_MODEL=dall-e-3           # Model for image generation
OPENAI_BASE_URL=                      # Optional: custom OpenAI endpoint

# --- Google Calendar (Agenda integration) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=

# --- Factuur / Invoice Settings ---
FACTUUR_BEDRIJFSNAAM=TopTalent Jobs
FACTUUR_ADRES=
FACTUUR_POSTCODE_STAD=
FACTUUR_KVK=
FACTUUR_BTW=
FACTUUR_IBAN=
FACTUUR_TENAAMSTELLING=
FACTUUR_EMAIL=facturen@toptalentjobs.nl
FACTUUR_BETAALTERMIJN_DAGEN=14

# --- Sentry (Error tracking & performance monitoring) ---
# Maak een gratis account aan op https://sentry.io
# Maak een nieuw project aan (Next.js) en kopieer de DSN
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=                    # Settings → Auth Tokens → Create New Token

# --- Notifications ---
NOTIFICATION_EMAIL=                   # Email for system notifications

# --- Push Notifications (Web Push / VAPID) ---
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Mollie (Payment processing voor boetes) ---
MOLLIE_API_KEY=                       # live_xxxxx voor production, test_xxxxx voor development
MOLLIE_WEBHOOK_BASE_URL=              # Base URL voor webhooks (bijv. https://www.toptalentjobs.nl)

# --- Database Backup ---
DATABASE_URL=                         # postgresql://postgres.[ref]:[ww]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
SUPABASE_DB_PASSWORD=                 # Database password (Supabase dashboard → Settings → Database)
